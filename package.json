{
  "name": "@viamrobotics/svelte-sdk",
  "description": "Build Svelte apps with Viam",
  "license": "Apache-2.0",
  "version": "1.2.3",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write . && eslint . --fix",
    "lint": "prettier --check . && eslint . && knip",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "test:e2e": "playwright test",
    "knip": "knip",
    "release": "changeset publish",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viamrobotics/viam-svelte-sdk.git"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^6.1.28",
    "@tanstack/svelte-query-devtools": "^6.1.28",
    "loglayer": "^9.1.0",
    "runed": "^0.37.1"
  },
  "peerDependencies": {
    "@viamrobotics/sdk": ">=0.57",
    "svelte": ">=5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@viamrobotics/prettier-config-svelte": "^2.0.0",
    "@viamrobotics/sdk": "^0.70.0",
    "@viamrobotics/typescript-config": "^0.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.19",
    "svelte": "5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "svelte"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.14.0"
}
