    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@fontsource-variable/public-sans": "^5.2.7",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "@viamrobotics/tailwind-config": "^1.0.0",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
